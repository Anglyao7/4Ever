# Caddy site address.
# Use your domain for automatic HTTPS, for example: 4ever.example.com
# Use :80 for HTTP-only testing.
SITE_ADDRESS=4ever.example.com
HTTP_PORT=80
HTTPS_PORT=443
VITE_API_BASE_URL=

CORS_ORIGINS=https://4ever.example.com,http://4ever.example.com
ALLOW_LEGACY_GLOBAL_MODEL_PROFILES=0

MODEL_PROFILE_ENCRYPTION_KEY=replace-with-stable-random-secret
CHAT_ATTACHMENT_URL_SECRET=replace-with-stable-random-secret
CHAT_ATTACHMENT_URL_TTL_SECONDS=600
CHAT_ATTACHMENT_UPLOAD_DIRNAME=chat-attachments

AI_TIMEOUT_SECONDS=120
AGENT_GRAPH_RUNTIME=langgraph
AGENT_SYNTHESIS_LIVE=0

BIGMODEL_API_KEY=
BIGMODEL_MCP_LIVE=0
MCP_TIMEOUT_SECONDS=30
MCP_RESULT_MAX_CHARS=3000

TENCENT_MAP_KEY=
TENCENT_MAP_SIGNATURE_KEY=
